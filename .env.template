# Anthropic — required. Used by agent.py for all research jobs.
ANTHROPIC_API_KEY=

# Telegram — required. Used by telegram_bot.py for daily brief delivery.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Brave Search — REQUIRED for finance-geo and ai-fringe jobs.
# These jobs pre-fetch web results via Brave so the LLM can ground its
# market figures and headlines in current data. WITHOUT this key,
# fetch_brave_search() returns "[Brave Search: no API key]" for every
# call, the LLM correctly refuses to fabricate prices, and the briefs
# come out empty/apologetic.
# Free tier: 2000 queries/month (Clippy uses ~150/month). Sign up at
# https://api-dashboard.search.brave.com — token format BSA-xxxxxxxx.
BRAVE_API_KEY=

# GitHub — optional. Used by fetch_github_releases() in ai-fringe to
# track new releases of monitored repos (anthropic-sdk-python, MCP
# servers, litellm, etc.). Without it, GitHub allows 60 req/hour
# anonymously which is enough for our once-daily fetch. With a token,
# limit is 5000/hour. Generate at https://github.com/settings/tokens —
# fine-grained, public_repo read scope only.
GITHUB_TOKEN=

# OpenRouter — optional cost optimization. If set, the primary LLM for
# all research jobs becomes Qwen 3 235B via OpenRouter (cheap, web
# plugin enabled); if the call fails, agent.py automatically falls back
# to Claude Haiku via Anthropic. If unset, Anthropic Haiku is the
# primary directly. Both paths support web search.
OPENROUTER_API_KEY=

# clippy-api.py /chat endpoint auth. Generate with: openssl rand -hex 32
# Required if anything calls /chat; otherwise the API will reject requests.
AGENT_API_KEY=

# Darwin integration — optional. If both are set, scheduler.py will POST each
# job's findings to Darwin's /ingest endpoint after delivering to Telegram.
# If either is empty, the hook is a no-op (Clippy runs unchanged).
#   DARWIN_INGEST_URL: e.g. http://NintendoPI.local:8769/ingest
#   DARWIN_API_KEY:    copy from Darwin's /home/darwin/darwin/.env
DARWIN_INGEST_URL=
DARWIN_API_KEY=
